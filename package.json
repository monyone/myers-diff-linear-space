{
  "name": "@monyone/myers-diff-linear-space",
  "version": "0.0.2",
  "author": "monyone <monyone.teihen@gmail.com>",
  "description": "Myers Algorithm (Linear Space) written in TypeScript",
  "keywords": [
    "diff",
    "myers",
    "myers-diff"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "license": "MIT",
  "files": [
    "dist/**/*",
    "src/**/*",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "tsdown",
    "tsc": "tsc",
    "test": "vitest",
    "prepublishOnly": "tsdown"
  },
  "devDependencies": {
    "tsdown": "^0.21.10",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
